# Servidor
PORT=3000
NODE_ENV=development

# Banco de dados (caminho do arquivo SQLite)
DB_PATH=database.sqlite

# JWT — use um secret longo e aleatório em produção
JWT_SECRET=troque_por_um_secret_forte

# Chave de criptografia (32 bytes em hex = 64 caracteres)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=coloque_aqui_64_caracteres_hex

# Asaas (gateway de pagamento PIX)
# Sandbox:    https://api-sandbox.asaas.com/v3
# Produção:   https://api.asaas.com/v3
ASAAS_API_KEY=sua_api_key_do_asaas
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3
# Token configurado no painel do Asaas para validar webhooks
ASAAS_WEBHOOK_TOKEN=token_compartilhado_com_o_asaas

# CORS — origens permitidas, separadas por vírgula
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# Trust proxy — SÓ em produção, quando o backend roda atrás de um proxy reverso
# (nginx, load balancer, PaaS) que repassa o IP real do cliente em X-Forwarded-For.
# Sem isto, os rate limiters por IP veriam o IP do proxy (tratando todos como um só).
# Valor: nº de proxies à frente (ex.: 1) ou lista de IPs (ex.: "loopback, 10.0.0.0/8").
# NUNCA use "true" (confiar em todos permite forjar o header e burlar o rate limit).
# Em dev (sem proxy) deixe vazio/comentado — o padrão do Express usa o IP do socket.
# TRUST_PROXY=1

# Logging — níveis: trace, debug, info, warn, error, fatal
# Default: info. Em produção, considere "warn" para reduzir ruído.
LOG_LEVEL=info
